---
import { env } from 'cloudflare:workers'

const freeOpen = env.FREE_OPEN === 'true'
const proOpen = env.PRO_OPEN === 'true'

// Handle Free signup form error params
const signupError = Astro.url.searchParams.get('error')
const signupErrorMessage =
  signupError === 'invalid-email' ? 'Please enter a valid email address.' :
  signupError === 'rate-limit' ? 'Too many attempts. Please wait a few minutes.' :
  signupError === 'server' ? 'Something went wrong. Please try again.' :
  null

// Fetch live prices from Stripe in parallel
type StripePrice = { unit_amount: number | null; currency: string; recurring?: { interval: string } }
let proPrice: StripePrice | null = null
let enterprisePrice: StripePrice | null = null
try {
  const [proRes, entRes] = await Promise.all([
    fetch(`https://api.stripe.com/v1/prices/${env.STRIPE_PRO_PRICE_ID}`, {
      headers: { Authorization: `Basic ${btoa(env.STRIPE_SECRET_KEY + ':')}` },
      signal: AbortSignal.timeout(4000),
    }),
    fetch(`https://api.stripe.com/v1/prices/${env.STRIPE_ENTERPRISE_PRICE_ID}`, {
      headers: { Authorization: `Basic ${btoa(env.STRIPE_SECRET_KEY + ':')}` },
      signal: AbortSignal.timeout(4000),
    }),
  ])
  if (proRes.ok) proPrice = await proRes.json() as StripePrice
  if (entRes.ok) enterprisePrice = await entRes.json() as StripePrice
} catch { /* fall back to placeholders */ }

function formatPrice(p: StripePrice | null, fallback: string): string {
  if (p?.unit_amount == null) return fallback
  return new Intl.NumberFormat('en', { style: 'currency', currency: p.currency.toUpperCase(), maximumFractionDigits: 0 }).format(p.unit_amount / 100)
}

const priceAmount = formatPrice(proPrice, '$29')
const priceInterval = proPrice?.recurring?.interval ?? 'month'
const enterprisePriceAmount = formatPrice(enterprisePrice, '$79')
const enterprisePriceInterval = enterprisePrice?.recurring?.interval ?? 'month'
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Get started — TaxVett</title>
  <meta name="theme-color" content="#10A6E8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;700&family=Manrope:wght@500;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #f8fafc; --surface: #ffffff;
      --border: #e2e8f0; --border-muted: #cbd5e1;
      --text: #1e293b; --text-heading: #0f172a; --text-muted: #64748b; --text-body: #334155;
      --brand: #0ea5e9; --brand-hover: #0284c7;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #0f172a; --surface: #1e293b;
        --border: #334155; --border-muted: #475569;
        --text: #e2e8f0; --text-heading: #f1f5f9; --text-muted: #94a3b8; --text-body: #cbd5e1;
        --brand: #38bdf8; --brand-hover: #0ea5e9;
      }
      .plan-badge { background: #0c4a6e !important; color: #7dd3fc !important; }
      .plan-badge.pro { background: #451a03 !important; color: #fcd34d !important; }
      .plan-badge.enterprise { background: #3b0764 !important; color: #d8b4fe !important; }
      .btn-pro { background: #e2e8f0 !important; color: #0f172a !important; }
      .coming-soon-pill { background: rgba(56,189,248,.1) !important; border-color: rgba(56,189,248,.3) !important; color: #38bdf8 !important; }
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "Manrope", system-ui, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
    nav { display: flex; align-items: center; justify-content: space-between; padding: 0 24px; height: 56px; border-bottom: 1px solid var(--border); background: var(--surface); }
    .logo { display: inline-flex; align-items: center; gap: 10px; color: var(--text-heading); text-decoration: none; }
    .logo img { width: 26px; height: 26px; flex-shrink: 0; }
    .logo strong { font-size: 18px; font-weight: 800; letter-spacing: -.03em; }
    .nav-links { display: flex; gap: 20px; align-items: center; }
    .nav-links a { font-size: 14px; color: var(--text-muted); text-decoration: none; }
    .nav-links a:hover { color: var(--brand); }
    .page { max-width: 820px; margin: 0 auto; padding: 56px 24px; }
    h1 { font-size: 30px; font-weight: 800; text-align: center; margin-bottom: 8px; }
    .subtitle { text-align: center; color: var(--text-muted); font-size: 16px; margin-bottom: 48px; }
    .plans { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    @media (max-width: 860px) { .plans { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 560px) { .plans { grid-template-columns: 1fr; } }
    .plan-card { background: var(--surface); border: 2px solid var(--border); border-radius: 14px; padding: 28px; display: flex; flex-direction: column; }
    .plan-card.highlighted { border-color: var(--brand); }
    .plan-badge { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; padding: 3px 10px; border-radius: 20px; background: #e0f2fe; color: #0369a1; width: fit-content; margin-bottom: 16px; }
    .plan-badge.pro { background: #fef9c3; color: #854d0e; }
    .plan-badge.enterprise { background: #f3e8ff; color: #6b21a8; }
    .plan-name { font-size: 22px; font-weight: 800; margin-bottom: 4px; }
    .plan-price { font-size: 32px; font-weight: 800; color: var(--text-heading); margin-bottom: 4px; }
    .plan-price span { font-size: 15px; font-weight: 500; color: var(--text-muted); }
    .plan-desc { font-size: 14px; color: var(--text-muted); margin-bottom: 20px; line-height: 1.6; }
    .plan-features { list-style: none; margin-bottom: 28px; flex: 1; }
    .plan-features li { font-size: 14px; padding: 5px 0; display: flex; align-items: center; gap: 8px; color: var(--text-body); }
    .plan-features li::before { content: "✓"; color: var(--brand); font-weight: 700; flex-shrink: 0; }
    .plan-from { font-size: 12px; color: var(--text-muted); font-style: italic; margin-bottom: 8px; }
    .btn { width: 100%; padding: 12px; border: none; border-radius: 8px; font-size: 15px; font-weight: 700; cursor: pointer; text-align: center; display: block; text-decoration: none; box-sizing: border-box; }
    .btn-enterprise { background: #6b21a8; color: #fff; }
    .btn-enterprise:hover { background: #581c87; }
    .coming-soon-pill { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; padding: 11px 12px; border-radius: 8px; font-size: 14px; font-weight: 600; background: rgba(14,165,233,.08); border: 1px dashed rgba(14,165,233,.35); color: var(--brand); }
    .coming-soon-pill span { font-family: "IBM Plex Mono", monospace; font-size: 11px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; opacity: .8; }
    .login-hint { text-align: center; margin-top: 32px; font-size: 14px; color: var(--text-muted); }
    .login-hint a { color: var(--brand); text-decoration: none; font-weight: 500; }
    .login-hint a:hover { text-decoration: underline; }
    .legal-hint { text-align: center; margin-top: 16px; font-size: 12px; color: var(--text-muted); }
    .legal-hint a { color: var(--text-muted); text-decoration: underline; }
    .error-msg { color: #ef4444; font-size: 13px; margin-bottom: 8px; }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="logo"><img src="/brand/logo-mark.svg" alt="" /><strong>TaxVett</strong></a>
    <div class="nav-links">
      <a href="https://api.taxvett.com/docs" target="_blank" rel="noopener">API Docs</a>
      <a href="/login">Log in</a>
    </div>
  </nav>

  <div class="page">
    <h1>Get started with TaxVett</h1>
    <p class="subtitle">Pick the plan that fits your needs. Upgrade anytime.</p>

    <div class="plans">
      <!-- Free plan -->
      <div class="plan-card">
        <div class="plan-badge">Free</div>
        <div class="plan-name">Developer</div>
        <div class="plan-price">$0 <span>/ month</span></div>
        <p class="plan-desc">Perfect for trying out the API and low-volume projects.</p>
        <ul class="plan-features">
          <li>100 req/month</li>
          <li>10 req/min rate limit</li>
          <li>Single validation endpoint</li>
          <li>30+ countries</li>
          <li>Dashboard &amp; API key management</li>
        </ul>
        {freeOpen ? (
          <form action="/api/signup-free" method="POST" id="free-signup-form">
            {signupErrorMessage && <p class="error-msg">{signupErrorMessage}</p>}
            <input type="email" name="email" placeholder="you@company.com" required autocomplete="email" style="width:100%;padding:10px 12px;border:1px solid var(--border-muted);border-radius:6px;font-size:14px;margin-bottom:8px;background:var(--surface);color:var(--text);box-sizing:border-box" />
            <button type="submit" id="free-submit" class="btn" style="background:var(--surface);border:1px solid var(--border-muted);color:var(--text);font-weight:600">Get started free →</button>
          </form>
        ) : (
          <div class="coming-soon-pill"><span>Coming soon</span></div>
        )}
      </div>

      <!-- Pro plan -->
      <div class="plan-card highlighted">
        <div class="plan-badge pro">Professional</div>
        <div class="plan-name">Pro</div>
        <div class="plan-price">{priceAmount} <span>/ {priceInterval}</span></div>
        <p class="plan-desc">For production workloads that need higher throughput and SLA.</p>
        <p class="plan-from">Everything in Developer, plus:</p>
        <ul class="plan-features">
          <li>5 000 req/month</li>
          <li>60 req/min rate limit</li>
          <li>Batch validation (up to 50)</li>
          <li>Priority support</li>
        </ul>
        {proOpen ? (
          <button id="pro-checkout-btn" class="btn btn-pro" style="background:var(--brand);color:#fff">Get started →</button>
        ) : (
          <div class="coming-soon-pill"><span>Coming soon</span></div>
        )}
      </div>

      <!-- Enterprise plan -->
      <div class="plan-card">
        <div class="plan-badge enterprise">Large Enterprise</div>
        <div class="plan-name">Scale</div>
        <div class="plan-price">{enterprisePriceAmount} <span>/ {enterprisePriceInterval}</span></div>
        <p class="plan-desc">Maximum throughput, guaranteed uptime, and dedicated support for demanding integrations.</p>
        <p class="plan-from">Everything in Pro, plus:</p>
        <ul class="plan-features">
          <li>Unlimited req/month</li>
          <li>300 req/min rate limit</li>
          <li>99.9% SLA</li>
          <li>Dedicated support</li>
        </ul>
        <a href="mailto:support@taxvett.com" class="btn btn-enterprise">Contact us →</a>
      </div>
    </div>

    <p class="login-hint">Already have an account? <a href="/login">Sign in</a></p>
    <p class="legal-hint">By signing up you agree to our <a href="/terms">Terms of Service</a> and <a href="/privacy">Privacy Policy</a>.</p>
  </div>
</body>
</html>

<script>
  // Pro checkout
  const proBtn = document.getElementById('pro-checkout-btn')
  if (proBtn) {
    proBtn.addEventListener('click', async () => {
      proBtn.setAttribute('disabled', 'true')
      proBtn.textContent = 'Redirecting…'
      try {
        const res = await fetch('/api/checkout', { method: 'POST' })
        const { url } = await res.json()
        window.location.href = url
      } catch {
        proBtn.removeAttribute('disabled')
        proBtn.textContent = 'Get started →'
      }
    })
  }
  // Free signup loading state
  const freeForm = document.getElementById('free-signup-form')
  const freeSubmit = document.getElementById('free-submit')
  if (freeForm && freeSubmit) {
    freeForm.addEventListener('submit', () => {
      freeSubmit.setAttribute('disabled', 'true')
      freeSubmit.textContent = 'Sending…'
    })
  }
</script>
