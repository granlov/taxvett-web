---
// Landing page — taxvett.com
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TaxVett — Global Tax Number Validation API</title>
  <meta name="description" content="Validate EU VAT, UK, Australian, Norwegian and Singapore tax numbers in one API call. Free to start." />
  <meta name="theme-color" content="#10A6E8" />
  <meta property="og:title" content="TaxVett — Global Tax Number Validation API" />
  <meta property="og:description" content="Validate EU VAT, UK, Australian, Norwegian and Singapore tax numbers in one API call. Free to start." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://taxvett.com/" />
  <meta property="og:image" content="https://taxvett.com/og-image.svg" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="TaxVett — Global Tax Number Validation API" />
  <meta name="twitter:description" content="Validate EU VAT, UK, Australian, Norwegian and Singapore tax numbers in one API call. Free to start." />
  <meta name="twitter:image" content="https://taxvett.com/og-image.svg" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;700&family=Manrope:wght@500;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #ffffff; --surface: #ffffff; --surface-alt: #f8fafc; --surface-alt2: #f1f5f9;
      --border: #e2e8f0; --border-muted: #cbd5e1;
      --text: #1e293b; --text-heading: #0f172a; --text-muted: #64748b; --text-faint: #94a3b8; --text-code: #475569;
      --brand: #0ea5e9; --brand-hover: #0284c7; --brand-light: #f0f9ff;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #0f172a; --surface: #1e293b; --surface-alt: #1e293b; --surface-alt2: #263348;
        --border: #334155; --border-muted: #475569;
        --text: #e2e8f0; --text-heading: #f1f5f9; --text-muted: #94a3b8; --text-faint: #64748b; --text-code: #94a3b8;
        --brand: #38bdf8; --brand-hover: #0ea5e9; --brand-light: #0c4a6e;
      }
      .result-valid { background: #14532d !important; color: #86efac !important; }
      .result-invalid { background: #450a0a !important; color: #fca5a5 !important; }
      .result-error { background: #431407 !important; color: #fdba74 !important; }
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "Manrope", system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--text); }

    nav { display: flex; align-items: center; justify-content: space-between; padding: 0 24px; height: 60px; border-bottom: 1px solid var(--border); max-width: 1100px; margin: 0 auto; }
    .logo { display: inline-flex; align-items: center; gap: 10px; color: var(--text-heading); }
    .logo img { width: 28px; height: 28px; flex-shrink: 0; }
    .logo strong { font-size: 20px; font-weight: 800; letter-spacing: -.03em; }
    .nav-links { display: flex; gap: 24px; align-items: center; }
    .nav-links a { font-size: 14px; color: var(--text-muted); text-decoration: none; }
    .nav-links a:hover { color: var(--brand); }
    .btn-nav { background: var(--brand); color: #fff !important; padding: 8px 18px; border-radius: 6px; font-weight: 600 !important; }
    .btn-nav:hover { background: var(--brand-hover) !important; }

    .hero { max-width: 820px; margin: 0 auto; padding: 80px 24px 60px; text-align: center; }
    .hero h1 { font-size: clamp(32px, 5vw, 54px); font-weight: 800; line-height: 1.15; margin-bottom: 20px; }
    .hero h1 span { color: var(--brand); }
    .hero p { font-size: 18px; color: var(--text-muted); max-width: 560px; margin: 0 auto 36px; line-height: 1.6; }
    .hero-ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-primary { background: var(--brand); color: #fff; padding: 13px 28px; border-radius: 8px; font-size: 16px; font-weight: 700; text-decoration: none; }
    .btn-primary:hover { background: var(--brand-hover); }
    .btn-secondary { background: var(--surface-alt); color: var(--text); border: 1px solid var(--border); padding: 13px 28px; border-radius: 8px; font-size: 16px; font-weight: 600; text-decoration: none; }
    .btn-secondary:hover { background: var(--surface-alt2); }

    .demo-section { max-width: 680px; margin: 0 auto 80px; padding: 0 24px; }
    .demo-card { background: var(--surface-alt); border: 1px solid var(--border); border-radius: 14px; padding: 32px; }
    .demo-card h2 { font-size: 20px; font-weight: 700; margin-bottom: 6px; }
    .demo-card p { font-size: 14px; color: var(--text-muted); margin-bottom: 20px; }
    .demo-examples { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
    .example-btn { font-size: 12px; padding: 5px 10px; border: 1px solid var(--border-muted); background: var(--surface); border-radius: 20px; cursor: pointer; color: var(--text-code); }
    .example-btn:hover { border-color: var(--brand); color: var(--brand); }
    .demo-input-row { display: flex; gap: 10px; }
    .demo-input { flex: 1; padding: 11px 14px; border: 1px solid var(--border-muted); border-radius: 8px; font-size: 15px; outline: none; background: var(--surface); color: var(--text); }
    .demo-input:focus { border-color: var(--brand); box-shadow: 0 0 0 3px rgba(14,165,233,.12); }
    .demo-btn { background: var(--brand); color: #fff; border: none; padding: 11px 22px; border-radius: 8px; font-size: 15px; font-weight: 700; cursor: pointer; white-space: nowrap; }
    .demo-btn:hover { background: var(--brand-hover); }
    .demo-btn:disabled { opacity: .6; cursor: not-allowed; }
    .demo-result { margin-top: 20px; border-radius: 8px; overflow: hidden; border: 1px solid var(--border); }
    .result-header { display: flex; align-items: center; gap: 10px; padding: 12px 16px; font-size: 14px; font-weight: 600; }
    .result-valid { background: #f0fdf4; color: #15803d; }
    .result-invalid { background: #fef2f2; color: #dc2626; }
    .result-error { background: #fff7ed; color: #c2410c; }
    .result-body { background: var(--surface); padding: 14px 16px; font-size: 13px; color: var(--text-code); line-height: 1.7; font-family: "IBM Plex Mono", monospace; }
    .result-body strong { color: var(--text); }

    .features { background: var(--surface-alt); padding: 72px 24px; }
    .features-inner { max-width: 1100px; margin: 0 auto; }
    .features h2 { font-size: 28px; font-weight: 800; text-align: center; margin-bottom: 48px; }
    .feature-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 24px; }
    .feature { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 24px; }
    .feature-icon { font-size: 28px; margin-bottom: 12px; }
    .feature h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
    .feature p { font-size: 14px; color: var(--text-muted); line-height: 1.6; }

    .coverage { max-width: 820px; margin: 0 auto; padding: 72px 24px; text-align: center; }
    .coverage h2 { font-size: 28px; font-weight: 800; margin-bottom: 16px; }
    .coverage p { color: var(--text-muted); margin-bottom: 32px; }
    .flags { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; font-size: 13px; }
    .flag-item { display: flex; align-items: center; gap: 6px; background: var(--surface-alt); border: 1px solid var(--border); border-radius: 20px; padding: 5px 12px; }

    .cta { background: var(--brand); color: #fff; text-align: center; padding: 72px 24px; }
    .cta h2 { font-size: 32px; font-weight: 800; margin-bottom: 12px; }
    .cta p { font-size: 16px; opacity: .9; margin-bottom: 28px; }
    .btn-white { background: #fff; color: var(--brand); padding: 13px 28px; border-radius: 8px; font-size: 16px; font-weight: 700; text-decoration: none; }
    .btn-white:hover { background: var(--brand-light); }

    footer { text-align: center; padding: 32px 24px; font-size: 13px; color: var(--text-faint); border-top: 1px solid var(--border); }
    footer a { color: var(--text-faint); text-decoration: none; }
    footer a:hover { color: var(--brand); }
  </style>
</head>
<body>

<nav>
  <a href="/" class="logo" style="text-decoration:none">
    <img src="/brand/logo-mark.svg" alt="" />
    <strong>TaxVett</strong>
  </a>
  <div class="nav-links">
    <a href="https://api.taxvett.com/docs" target="_blank" rel="noopener">API Docs</a>
    <a href="/login">Log in</a>
    <a href="/signup" class="btn-nav">Get started →</a>
  </div>
</nav>

<section class="hero">
  <h1>Validate any <span>tax number</span><br/>in one API call</h1>
  <p>EU VAT, UK, Australia, Norway, Singapore — one endpoint, global coverage. Built on Cloudflare for &lt;50ms latency.</p>
  <div class="hero-ctas">
    <a href="/signup" class="btn-primary">Get started free</a>
    <a href="https://api.taxvett.com/docs" target="_blank" rel="noopener" class="btn-secondary">View API docs</a>
  </div>
</section>

<section class="demo-section">
  <div class="demo-card">
    <h2>Try it now — no signup required</h2>
    <p>Enter a real tax number below and see a live validation response.</p>
    <div class="demo-examples">
      <button class="example-btn" data-value="SE556677881301">🇸🇪 SE556677881301</button>
      <button class="example-btn" data-value="GB123456789">🇬🇧 GB123456789</button>
      <button class="example-btn" data-value="DE129274202">🇩🇪 DE129274202</button>
      <button class="example-btn" data-value="51824753556">🇦🇺 51 824 753 556</button>
    </div>
    <div class="demo-input-row">
      <input
        type="text"
        id="demo-input"
        class="demo-input"
        placeholder="Enter a tax number, e.g. SE556677881301"
        autocomplete="off"
        spellcheck="false"
      />
      <button id="demo-btn" class="demo-btn">Validate</button>
    </div>
    <div id="demo-result" class="demo-result" hidden></div>
  </div>
</section>

<section class="features">
  <div class="features-inner">
    <h2>Everything you need for B2B checkout</h2>
    <div class="feature-grid">
      <div class="feature">
        <div class="feature-icon">🌍</div>
        <h3>30+ countries</h3>
        <p>EU27, UK HMRC, Australian ABN, Norwegian Brønnøysund, Singapore IRAS — all from a single endpoint.</p>
      </div>
      <div class="feature">
        <div class="feature-icon">⚡</div>
        <h3>Sub-50ms response time</h3>
        <p>Deployed at the network edge globally with Redis caching. Results in milliseconds, not seconds.</p>
      </div>
      <div class="feature">
        <div class="feature-icon">🔁</div>
        <h3>Automatic retry & fallback</h3>
        <p>VIES down? We fall back to SOAP and retry with exponential backoff for maximum uptime.</p>
      </div>
      <div class="feature">
        <div class="feature-icon">📦</div>
        <h3>Batch validation</h3>
        <p>Validate up to 50 numbers in a single POST. Perfect for import flows and overnight reconciliation.</p>
      </div>
      <div class="feature">
        <div class="feature-icon">📊</div>
        <h3>Validation intelligence</h3>
        <p>Your dashboard shows success rates, top countries, and usage trends — not just raw call counts.</p>
      </div>
    </div>
  </div>
</section>

<section class="coverage">
  <h2>Countries covered</h2>
  <p>Automatic detection — just pass the tax number, we detect the country and route it correctly.</p>
  <div class="flags">
    {[
      ['🇦🇹','Austria'],['🇧🇪','Belgium'],['🇧🇬','Bulgaria'],['🇨🇾','Cyprus'],['🇨🇿','Czechia'],
      ['🇩🇰','Denmark'],['🇪🇪','Estonia'],['🇫🇮','Finland'],['🇫🇷','France'],['🇩🇪','Germany'],
      ['🇬🇷','Greece'],['🇭🇺','Hungary'],['🇮🇪','Ireland'],['🇮🇹','Italy'],['🇱🇻','Latvia'],
      ['🇱🇹','Lithuania'],['🇱🇺','Luxembourg'],['🇲🇹','Malta'],['🇳🇱','Netherlands'],['🇵🇱','Poland'],
      ['🇵🇹','Portugal'],['🇷🇴','Romania'],['🇸🇰','Slovakia'],['🇸🇮','Slovenia'],['🇪🇸','Spain'],
      ['🇸🇪','Sweden'],['🇬🇧','United Kingdom'],['🇦🇺','Australia'],['🇳🇴','Norway'],['🇸🇬','Singapore'],
    ].map(([flag, name]) => (
      <span class="flag-item">{flag} {name}</span>
    ))}
  </div>
</section>

<section class="cta">
  <h2>Start validating in minutes</h2>
  <p>Free plan included. No credit card required.</p>
  <a href="/signup" class="btn-white">Get your API key →</a>
</section>

<footer>
  <p>© 2026 TaxVett · <a href="https://api.taxvett.com/docs">API Docs</a> · <a href="https://api.taxvett.com/llms.txt">llms.txt</a></p>
</footer>

<script>
  const input = document.getElementById('demo-input') as HTMLInputElement
  const btn = document.getElementById('demo-btn') as HTMLButtonElement
  const result = document.getElementById('demo-result') as HTMLDivElement

  document.querySelectorAll('.example-btn').forEach((el) => {
    el.addEventListener('click', () => {
      input.value = (el as HTMLButtonElement).dataset.value ?? ''
      input.focus()
    })
  })

  async function runValidation() {
    const number = input.value.trim()
    if (!number) { input.focus(); return }

    btn.disabled = true
    btn.textContent = 'Validating…'
    result.hidden = true

    try {
      const res = await fetch('/api/demo-validate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ number }),
      })
      const data = await res.json() as Record<string, unknown>

      let headerClass = 'result-error'
      let headerText = '⚠ Error'
      if (res.ok) {
        if (data.valid === true) {
          headerClass = 'result-valid'
          headerText = '✓ Valid tax number'
        } else {
          headerClass = 'result-invalid'
          headerText = '✗ Invalid or not found'
        }
      }

      const lines: string[] = []
      if (data.number) lines.push(`<strong>Number:</strong> ${String(data.number)}`)
      if (data.country) lines.push(`<strong>Country:</strong> ${String(data.country)}`)
      if (data.company_name) lines.push(`<strong>Company:</strong> ${String(data.company_name)}`)
      if (data.company_address) lines.push(`<strong>Address:</strong> ${String(data.company_address)}`)
      if (data.message) lines.push(`<strong>Message:</strong> ${String(data.message)}`)
      if (data.error) lines.push(`<strong>Error:</strong> ${String(data.error)}`)

      result.innerHTML = `
        <div class="result-header ${headerClass}">${headerText}</div>
        <div class="result-body">${lines.join('<br/>') || JSON.stringify(data, null, 2)}</div>
      `
    } catch {
      result.innerHTML = `
        <div class="result-header result-error">⚠ Network error</div>
        <div class="result-body">Could not reach the validation API. Please try again.</div>
      `
    }

    result.hidden = false
    btn.disabled = false
    btn.textContent = 'Validate'
  }

  btn.addEventListener('click', runValidation)
  input.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Enter') runValidation() })
</script>
</body>
</html>

