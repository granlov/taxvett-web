---
import { getDb } from '../../lib/db.ts'
import { getRedis } from '../../lib/redis.ts'
import { generateMagicToken, checkMagicLinkRateLimit } from '../../lib/auth.ts'
import { sendMagicLinkEmail } from '../../lib/email.ts'
import { eq } from 'drizzle-orm'
import { apiKeys } from '../../db/schema.ts'
import { env } from 'cloudflare:workers'

let error = ''
let success = false

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData()
  const email = String(data.get('email') ?? '').trim().toLowerCase()

  if (!email || !email.includes('@')) {
    error = 'Please enter a valid email address.'
  } else {
    try {
      const db = getDb(env.DATABASE_URL)
      const redis = getRedis(
        env.UPSTASH_REDIS_REST_URL,
        env.UPSTASH_REDIS_REST_TOKEN,
      )

      const allowed = await checkMagicLinkRateLimit(redis, email)
      if (!allowed) {
        error = 'Too many login attempts. Please wait a few minutes and try again.'
      } else {
        const key = await db.query.apiKeys.findFirst({
          where: eq(apiKeys.email, email),
          columns: { id: true },
        })

        // Don't reveal whether the email exists — always show success
        if (key) {
          const token = await generateMagicToken(redis, key.id)
          const magicLink = `${Astro.url.origin}/login/callback?token=${token}`
          await sendMagicLinkEmail({
            to: email,
            magicLink,
            resendApiKey: env.RESEND_API_KEY,
          })
        }

        success = true
      }
    } catch (e) {
      console.error('[login POST error]', e instanceof Error ? e.message : String(e), e instanceof Error ? e.stack : '')
      error = 'Something went wrong. Please try again.'
    }
  }
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign in — TaxVett</title>
  <meta name="theme-color" content="#10A6E8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;700&family=Manrope:wght@500;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #f8fafc; --surface: #ffffff; --surface-alt: #f8fafc;
      --border: #e2e8f0; --border-muted: #cbd5e1;
      --text: #1e293b; --text-muted: #64748b; --text-faint: #94a3b8;
      --brand: #0ea5e9; --brand-hover: #0284c7;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #0f172a; --surface: #1e293b; --surface-alt: #1e293b;
        --border: #334155; --border-muted: #475569;
        --text: #e2e8f0; --text-muted: #94a3b8; --text-faint: #64748b;
        --brand: #38bdf8; --brand-hover: #0ea5e9;
      }
      .success { background: #14532d !important; border-color: #166534 !important; color: #86efac !important; }
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "Manrope", system-ui, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
    nav { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 24px; display: flex; align-items: center; justify-content: space-between; height: 56px; }
    .nav-logo { display: inline-flex; align-items: center; gap: 10px; color: var(--text-heading); text-decoration: none; }
    .nav-logo img { width: 26px; height: 26px; flex-shrink: 0; }
    .nav-logo strong { font-size: 18px; font-weight: 800; letter-spacing: -.03em; }
    .nav-links { display: flex; gap: 20px; align-items: center; }
    .nav-links a { font-size: 14px; color: var(--text-muted); text-decoration: none; }
    .nav-links a:hover { color: var(--brand); }
    .nav-links .btn-nav { background: var(--brand); color: #fff !important; padding: 7px 16px; border-radius: 6px; font-weight: 600; }
    .nav-links .btn-nav:hover { background: var(--brand-hover) !important; }
    .page-center { display: flex; align-items: center; justify-content: center; min-height: calc(100vh - 56px); padding: 24px; }
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 40px; width: 100%; max-width: 400px; }
    .logo { display: inline-flex; align-items: center; gap: 10px; margin-bottom: 24px; color: var(--text-heading); }
    .logo img { width: 30px; height: 30px; flex-shrink: 0; }
    .logo strong { font-size: 22px; font-weight: 800; letter-spacing: -.03em; }
    h1 { font-size: 22px; font-weight: 600; margin-bottom: 8px; }
    p { color: var(--text-muted); font-size: 14px; margin-bottom: 24px; }
    label { display: block; font-size: 13px; font-weight: 500; margin-bottom: 6px; }
    input[type="email"] { width: 100%; padding: 10px 12px; border: 1px solid var(--border-muted); border-radius: 6px; font-size: 15px; outline: none; background: var(--surface); color: var(--text); }
    input[type="email"]:focus { border-color: var(--brand); box-shadow: 0 0 0 3px rgba(14,165,233,.15); }
    button { width: 100%; margin-top: 16px; padding: 11px; background: var(--brand); color: #fff; border: none; border-radius: 6px; font-size: 15px; font-weight: 600; cursor: pointer; }
    button:hover { background: var(--brand-hover); }
    .error { color: #ef4444; font-size: 13px; margin-top: 10px; }
    .success { color: #16a34a; font-size: 14px; margin-top: 16px; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 6px; padding: 12px 14px; }
    .no-mail { margin-top: 12px; padding: 10px 14px; background: var(--surface-alt); border: 1px solid var(--border); border-radius: 6px; font-size: 13px; color: var(--text-muted); }
    .no-mail a { color: var(--brand); text-decoration: none; font-weight: 500; }
    .no-mail a:hover { text-decoration: underline; }
    .resend-btn { background: none; border: 1px solid var(--border-muted); border-radius: 6px; padding: 8px 14px; font-size: 13px; color: var(--text-muted); cursor: pointer; }
    .resend-btn:hover { border-color: var(--brand); color: var(--brand); }
    .resend-btn:disabled { opacity: .5; cursor: not-allowed; }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="nav-logo"><img src="/brand/logo-mark.svg" alt="" /><strong>TaxVett</strong></a>
    <div class="nav-links">
      <a href="https://api.taxvett.com/docs" target="_blank" rel="noopener">API Docs</a>
      <a href="/signup" class="btn-nav">Get started →</a>
    </div>
  </nav>
  <div class="page-center">
  <div class="card">
    <div class="logo"><img src="/brand/logo-mark.svg" alt="" /><strong>TaxVett</strong></div>
    <h1>Sign in to your dashboard</h1>
    {Astro.url.searchParams.get('welcome') === '1' && (
      <div style="margin-bottom:16px">
        <div class="success">
          ✓ Payment successful! A login link was sent to the email you used at checkout.
        </div>
        <div class="no-mail" style="margin-top:8px">
          Didn't receive it? Enter your email below to get a new link. Still stuck after 5 minutes?{' '}
          <a href="mailto:support@taxvett.com">Email support@taxvett.com</a> with your payment confirmation.
        </div>
      </div>
    )}
    <p>Enter the email you used to sign up. We'll send you a login link.</p>

    {success ? (
      <div>
        <div class="success">
          ✓ Check your inbox — we sent you a login link.
        </div>
        <div class="no-mail">
          No email after a minute? Check your spam folder.{' '}
          {Astro.url.searchParams.get('welcome') === '1'
            ? <span>If you just paid and still can't log in, email <a href="mailto:support@taxvett.com">support@taxvett.com</a> with your payment confirmation — we'll sort it out.</span>
            : <span>Address not recognised? <a href="/signup">Create an account</a> or <a href="mailto:support@taxvett.com">contact support</a>.</span>
          }
        </div>
        <form method="POST" id="resend-form" style="margin-top:14px">
          <input type="hidden" name="email" id="resend-email" value="" />
          <button type="button" id="resend-btn" class="resend-btn">Resend link</button>
        </form>
      </div>
    ) : (
      <form method="POST" id="login-form">
        <label for="email">Email address</label>
        <input type="email" id="email" name="email" placeholder="you@company.com" required autocomplete="email" autofocus />
        {error && <p class="error">{error}</p>}
        <button type="submit" id="submit-btn">Send login link</button>
      </form>
    )}
    <p style="margin-top:20px;font-size:13px;text-align:center;color:#94a3b8">
      Don't have an account? <a href="/signup" style="color:#0ea5e9;text-decoration:none;font-weight:500">Sign up free</a>
    </p>
  </div>
  </div>
  <script>
    const form = document.getElementById('login-form')
    const submitBtn = document.getElementById('submit-btn')
    const emailInput = document.getElementById('email')

    if (form && submitBtn) {
      form.addEventListener('submit', function () {
        submitBtn.setAttribute('disabled', 'true')
        submitBtn.textContent = 'Sending…'
      })
    }

    // Resend link: re-use the email entered before success
    const resendBtn = document.getElementById('resend-btn')
    const resendEmail = document.getElementById('resend-email')
    const resendForm = document.getElementById('resend-form')
    if (resendBtn && resendEmail && resendForm) {
      // Restore email from sessionStorage set before submit
      const storedEmail = sessionStorage.getItem('login_email')
      if (storedEmail) resendEmail.value = storedEmail

      resendBtn.addEventListener('click', async () => {
        if (!resendEmail.value) return
        resendBtn.setAttribute('disabled', 'true')
        resendBtn.textContent = 'Sending…'
        try {
          const fd = new FormData()
          fd.set('email', resendEmail.value)
          await fetch('/login', { method: 'POST', body: fd })
          resendBtn.textContent = 'Sent!'
          setTimeout(() => {
            resendBtn.removeAttribute('disabled')
            resendBtn.textContent = 'Resend link'
          }, 3000)
        } catch {
          resendBtn.removeAttribute('disabled')
          resendBtn.textContent = 'Resend link'
        }
      })
    }

    // Store email before submit so resend can use it
    if (form && emailInput) {
      form.addEventListener('submit', function () {
        sessionStorage.setItem('login_email', emailInput.value)
      })
    }

    if (emailInput) {
      emailInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
          e.preventDefault()
          const loginForm = document.getElementById('login-form')
          if (loginForm instanceof HTMLFormElement) {
            loginForm.requestSubmit()
          }
        }
      })
    }
  </script>
</body>
</html>
