---
import { getDb } from '../../lib/db.ts'
import { hashApiKey, generateApiKey } from '../../lib/crypto.ts'
import { eq, desc, sql } from 'drizzle-orm'
import { usageLog, apiKeys, webhooks } from '../../db/schema.ts'
import { env } from 'cloudflare:workers'

const db = getDb(env.DATABASE_URL)
const { apiKeyId, email, plan } = Astro.locals

// Handle key regeneration
let newKeyRaw: string | null = null
if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData()
  if (data.get('action') === 'regenerate-key') {
    const rawKey = await generateApiKey()
    const newHash = await hashApiKey(rawKey, env.API_KEY_SALT)
    await db.update(apiKeys)
      .set({ keyHash: newHash })
      .where(eq(apiKeys.id, apiKeyId))
    newKeyRaw = rawKey
    if (env.DISCORD_WEBHOOK_URL) {
      fetch(env.DISCORD_WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: `🔑 **API-nyckel regenererad** — konto \`${email ?? apiKeyId}\`` }),
        signal: AbortSignal.timeout(5000),
      }).catch(() => {})
    }
  } else if (data.get('action') === 'logout') {
    const { getRedis } = await import('../../lib/redis.ts')
    const { deleteSession } = await import('../../lib/auth.ts')
    const sessionId = Astro.cookies.get('session')?.value
    if (sessionId) {
      const redis = getRedis(env.UPSTASH_REDIS_REST_URL, env.UPSTASH_REDIS_REST_TOKEN)
      await deleteSession(redis, sessionId)
    }
    Astro.cookies.delete('session', { path: '/' })
    return Astro.redirect('/login')
  }
}

// Fetch stats
let totalRequests = 0
let monthlyRequests = 0
let byCountry: { country: string | null; count: number }[] = []
let byDay: { date: string; count: number }[] = []
let keyRow: { keyHash: string; createdAt: Date } | undefined = undefined
let webhookList: typeof import('../../db/schema.ts').webhooks.$inferSelect[] = []

try {
  const fourteenDaysAgo = sql`now() - interval '14 days'`
  const [totalResult, monthlyResult, byCountryResult, byDayResult, keyRowResult] = await Promise.all([
    db.select({ count: sql<number>`count(*)::int` }).from(usageLog).where(eq(usageLog.apiKeyId, apiKeyId)),
    db
      .select({ count: sql<number>`count(*)::int` })
      .from(usageLog)
      .where(sql`${usageLog.apiKeyId} = ${apiKeyId} AND ${usageLog.createdAt} >= date_trunc('month', now())`),
    db
      .select({ country: usageLog.country, count: sql<number>`count(*)::int` })
      .from(usageLog)
      .where(eq(usageLog.apiKeyId, apiKeyId))
      .groupBy(usageLog.country)
      .orderBy(desc(sql`count(*)`))
      .limit(5),
    db
      .select({
        date: sql<string>`date_trunc('day', ${usageLog.createdAt})::date::text`,
        count: sql<number>`count(*)::int`,
      })
      .from(usageLog)
      .where(sql`${usageLog.apiKeyId} = ${apiKeyId} AND ${usageLog.createdAt} >= ${fourteenDaysAgo}`)
      .groupBy(sql`date_trunc('day', ${usageLog.createdAt})`)
      .orderBy(sql`date_trunc('day', ${usageLog.createdAt})`),
    db.query.apiKeys.findFirst({ where: eq(apiKeys.id, apiKeyId), columns: { keyHash: true, createdAt: true } }),
  ])
  totalRequests = totalResult[0]?.count ?? 0
  monthlyRequests = monthlyResult[0]?.count ?? 0
  byCountry = byCountryResult
  byDay = byDayResult
  keyRow = keyRowResult
} catch (e) {
  console.error('[dashboard stats error]', e instanceof Error ? e.message : String(e))
}

try {
  webhookList = await db.select().from(webhooks).where(eq(webhooks.apiKeyId, apiKeyId)).orderBy(desc(webhooks.createdAt))
} catch (e) {
  console.error('[dashboard webhooks error]', e instanceof Error ? e.message : String(e))
}
const PLAN_MONTHLY_LIMITS: Record<string, number> = { free: 100, pro: 5000, enterprise: Infinity }
const planLimit = PLAN_MONTHLY_LIMITS[plan] ?? 100
const quotaPct = planLimit === Infinity ? 0 : Math.min(100, Math.round((monthlyRequests / planLimit) * 100))

// Build 14-day chart data (fill missing days with 0)
const today = new Date()
const chartDays: { date: string; count: number }[] = []
for (let i = 13; i >= 0; i--) {
  const d = new Date(today)
  d.setDate(d.getDate() - i)
  const dateStr = d.toISOString().slice(0, 10)
  const found = byDay.find((r) => r.date === dateStr)
  chartDays.push({ date: dateStr, count: found?.count ?? 0 })
}
const maxCount = Math.max(...chartDays.map((d) => d.count), 1)

const countryFlags: Record<string, string> = {
  SE: '🇸🇪', DE: '🇩🇪', GB: '🇬🇧', FR: '🇫🇷', NL: '🇳🇱', AU: '🇦🇺',
  NO: '🇳🇴', SG: '🇸🇬', FI: '🇫🇮', DK: '🇩🇰', PL: '🇵🇱', IT: '🇮🇹',
  ES: '🇪🇸', BE: '🇧🇪', AT: '🇦🇹', IE: '🇮🇪',
}

const keyPrefix = keyRow?.keyHash?.slice(0, 8) ?? '????????'
const createdAt = keyRow?.createdAt ? new Date(keyRow.createdAt).toLocaleDateString('en-SE') : '—'
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — TaxVett</title>
  <meta name="theme-color" content="#10A6E8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;700&family=Manrope:wght@500;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #f8fafc; --surface: #ffffff; --surface-alt: #f8fafc; --surface-alt2: #f1f5f9;
      --border: #e2e8f0; --border-muted: #cbd5e1;
      --text: #1e293b; --text-heading: #0f172a; --text-muted: #64748b; --text-faint: #94a3b8; --text-code: #475569;
      --brand: #0ea5e9; --brand-hover: #0284c7; --brand-light: #bae6fd; --brand-lighter: #7dd3fc;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #0f172a; --surface: #1e293b; --surface-alt: #1e293b; --surface-alt2: #263348;
        --border: #334155; --border-muted: #475569;
        --text: #e2e8f0; --text-heading: #f1f5f9; --text-muted: #94a3b8; --text-faint: #64748b; --text-code: #94a3b8;
        --brand: #38bdf8; --brand-hover: #0ea5e9; --brand-light: #075985; --brand-lighter: #0369a1;
      }
      .new-key-box { background: #14532d !important; border-color: #166534 !important; }
      .new-key-box strong { color: #86efac !important; }
      .new-key-box code { color: #f1f5f9 !important; }
      .plan-badge { background: #0c4a6e !important; color: #7dd3fc !important; }
      .plan-badge.pro { background: #451a03 !important; color: #fcd34d !important; }
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "Manrope", system-ui, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
    nav { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 24px; display: flex; align-items: center; justify-content: space-between; height: 56px; }
    .nav-logo { display: inline-flex; align-items: center; gap: 10px; color: var(--text-heading); text-decoration: none; }
    .nav-logo img { width: 26px; height: 26px; flex-shrink: 0; }
    .nav-logo strong { font-size: 18px; font-weight: 800; letter-spacing: -.03em; }
    .nav-right { display: flex; gap: 16px; align-items: center; font-size: 14px; color: var(--text-muted); }
    nav a { color: var(--text-muted); text-decoration: none; font-size: 14px; }
    nav a.nav-logo { color: var(--brand); font-weight: 700; }
    nav a.nav-docs { font-weight: 500; }
    nav a.nav-docs:hover { color: var(--brand); }
    main { max-width: 960px; margin: 0 auto; padding: 32px 24px; }
    h2 { font-size: 16px; font-weight: 600; margin-bottom: 16px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; margin-bottom: 28px; }
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 20px; }
    .card-title { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: var(--text-faint); margin-bottom: 8px; }
    .card-value { font-size: 28px; font-weight: 700; color: var(--text-heading); }
    .card-sub { font-size: 13px; color: var(--text-muted); margin-top: 4px; }
    .quota-bar { height: 8px; background: var(--border); border-radius: 4px; margin-top: 12px; overflow: hidden; }
    .quota-fill { height: 100%; border-radius: 4px; background: var(--brand); transition: width .4s; }
    .quota-fill.warning { background: #f59e0b; }
    .quota-fill.danger { background: #ef4444; }
    .section { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 24px; margin-bottom: 24px; }
    /* Bar chart */
    .chart { display: flex; align-items: flex-end; gap: 6px; height: 120px; margin-top: 8px; }
    .bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; height: 100%; justify-content: flex-end; }
    .bar { width: 100%; background: var(--brand-light); border-radius: 4px 4px 0 0; min-height: 2px; transition: height .3s; }
    .bar-label { font-size: 10px; color: var(--text-faint); white-space: nowrap; }
    .bar-count { font-size: 11px; color: var(--text-code); font-weight: 600; }
    /* Countries */
    .country-row { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--surface-alt2); }
    .country-row:last-child { border-bottom: none; }
    .country-name { flex: 1; font-size: 14px; }
    .country-bar-wrap { flex: 2; height: 8px; background: var(--surface-alt2); border-radius: 4px; overflow: hidden; }
    .country-bar { height: 100%; background: var(--brand-lighter); border-radius: 4px; }
    .country-count { font-size: 13px; font-weight: 600; color: var(--text-code); width: 36px; text-align: right; }
    /* API key */
    .key-box { display: flex; align-items: center; gap: 10px; background: var(--surface-alt); border: 1px solid var(--border); border-radius: 6px; padding: 10px 14px; font-family: "IBM Plex Mono", monospace; font-size: 14px; }
    .key-masked { flex: 1; color: var(--text-code); }
    .new-key-box { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 6px; padding: 14px; margin-bottom: 16px; }
    .new-key-box strong { display: block; font-size: 13px; margin-bottom: 8px; color: #15803d; }
    .new-key-box code { font-family: monospace; font-size: 13px; word-break: break-all; color: var(--text-heading); }
    .btn { padding: 8px 16px; border-radius: 6px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; }
    .btn-primary { background: var(--brand); color: #fff; }
    .btn-primary:hover { background: var(--brand-hover); }
    .btn-danger { background: var(--surface); color: #ef4444; border: 1px solid #fca5a5; }
    .btn-danger:hover { background: #fef2f2; }
    .btn-sm { padding: 6px 12px; font-size: 13px; }
    /* Webhooks */
    .webhook-row { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid var(--surface-alt2); }
    .webhook-row:last-child { border-bottom: none; }
    .webhook-url { flex: 1; font-size: 13px; font-family: "IBM Plex Mono", monospace; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .badge { font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 20px; }
    .badge-active { background: #dcfce7; color: #15803d; }
    .badge-inactive { background: var(--surface-alt); color: var(--text-faint); }
    .info-grid { display: grid; grid-template-columns: 140px 1fr; gap: 10px 0; font-size: 14px; }
    .info-label { color: var(--text-faint); font-weight: 500; }
    .plan-badge { font-size: 12px; font-weight: 700; padding: 2px 10px; border-radius: 20px; text-transform: uppercase; background: #e0f2fe; color: #0369a1; }
    .plan-badge.pro { background: #fef9c3; color: #854d0e; }
    form.inline { display: inline; }
    .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    input[type="url"] { flex: 1; padding: 8px 12px; border: 1px solid var(--border-muted); border-radius: 6px; font-size: 14px; background: var(--surface); color: var(--text); }
    .signout-btn { background: none; border: 1px solid var(--border); cursor: pointer; font-size: 13px; color: var(--text-muted); }
    .add-form { display: flex; gap: 8px; margin-top: 16px; }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="nav-logo"><img src="/brand/logo-mark.svg" alt="" /><strong>TaxVett</strong></a>
    <div class="nav-right">
      <a href="https://api.taxvett.com/docs" target="_blank" rel="noopener" class="nav-docs">API Docs</a>
      <span>{email}</span>
      <form method="POST" class="inline">
        <input type="hidden" name="action" value="logout" />
        <button class="btn btn-sm signout-btn">Sign out</button>
      </form>
    </div>
  </nav>

  <main>
    <!-- Quota cards -->
    <div class="grid">
      <div class="card">
        <div class="card-title">Requests this month</div>
        <div class="card-value">{monthlyRequests.toLocaleString()}</div>
        {planLimit !== Infinity ? (
          <div class="card-sub">{monthlyRequests.toLocaleString()} / {planLimit.toLocaleString()} this month</div>
        ) : (
          <div class="card-sub">unlimited</div>
        )}
        {planLimit !== Infinity && (
          <div class="quota-bar">
            <div
              class={`quota-fill${quotaPct >= 90 ? ' danger' : quotaPct >= 70 ? ' warning' : ''}`}
              style={`width:${quotaPct}%`}
            />
          </div>
        )}
      </div>
    </div>

    <!-- Requests per day chart -->
    <div class="section">
      <div class="section-header">
        <h2>Requests per day — last 14 days</h2>
      </div>
      <div class="chart">
        {chartDays.map((day) => (
          <div class="bar-col">
            <div class="bar-count">{day.count > 0 ? day.count : ''}</div>
            <div class="bar" style={`height:${Math.round((day.count / maxCount) * 100)}%`}></div>
            <div class="bar-label">{day.date.slice(5)}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Top countries -->
    {byCountry.length > 0 && (
      <div class="section">
        <h2>Top countries validated</h2>
        {byCountry.map((row) => {
          const flag = countryFlags[row.country ?? ''] ?? '🌍'
          const pct = totalRequests > 0 ? Math.round(((row.count ?? 0) / totalRequests) * 100) : 0
          return (
            <div class="country-row">
              <span style="font-size:20px">{flag}</span>
              <span class="country-name">{row.country ?? 'Unknown'}</span>
              <div class="country-bar-wrap">
                <div class="country-bar" style={`width:${pct}%`}></div>
              </div>
              <span class="country-count">{row.count}</span>
            </div>
          )
        })}
      </div>
    )}

    <!-- API key -->
    <div class="section">
      <div class="section-header">
        <h2>API key</h2>
      </div>

      {newKeyRaw && (
        <div class="new-key-box">
          <strong>⚠ Copy your new API key now — it won't be shown again.</strong>
          <code>{newKeyRaw}</code>
        </div>
      )}

      <div class="key-box">
        <span class="key-masked">tv_{'•'.repeat(20)}{keyPrefix}…</span>
        <form method="POST" onsubmit="return confirm('Regenerate API key? Your current key will stop working immediately.')">
          <input type="hidden" name="action" value="regenerate-key" />
          <button type="submit" class="btn btn-danger btn-sm">Regenerate</button>
        </form>
      </div>
    </div>

    {/* Webhooks — pausad, döljs tills vidare */}

    <!-- Account info + Plan (merged) -->
    <div class="section">
      <h2 style="margin-bottom:16px">Account</h2>
      <div class="info-grid">
        <span class="info-label">Email</span>
        <span>{email ?? '—'}</span>
        <span class="info-label">Plan</span>
        <span>
          <span class={`plan-badge ${plan === 'pro' ? 'pro' : ''}`}>{plan}</span>
          <span style="font-size:13px;color:var(--text-muted);margin-left:8px">{plan === 'pro' ? '60 req/min · 5,000/month' : plan === 'enterprise' ? '300 req/min · unlimited' : '10 req/min · 100/month'}</span>
        </span>
        <span class="info-label">API key created</span>
        <span>{createdAt}</span>
      </div>
      {plan !== 'pro' && plan !== 'enterprise' && (
        <button id="upgrade-btn" class="btn btn-primary btn-sm" style="margin-top:16px">Upgrade to Pro →</button>
      )}
    </div>
  </main>

  <script>
    const upgradeBtn = document.getElementById('upgrade-btn')
    if (upgradeBtn) {
      upgradeBtn.addEventListener('click', async () => {
        upgradeBtn.setAttribute('disabled', 'true')
        upgradeBtn.textContent = 'Redirecting…'
        try {
          const res = await fetch('/api/checkout', { method: 'POST' })
          const { url } = await res.json() as { url: string }
          window.location.href = url
        } catch {
          upgradeBtn.removeAttribute('disabled')
          upgradeBtn.textContent = 'Upgrade to Pro →'
          alert('Something went wrong. Please try again.')
        }
      })
    }
  </script>
</body>
</html>
