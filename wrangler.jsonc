{
	"compatibility_date": "2026-05-01",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "taxvett-web",
	"pages_build_output_dir": "./dist",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"vars": {
		"PUBLIC_API_BASE": "https://api.taxvett.com"
	}
}